# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key

# Backend API
NEXT_PUBLIC_BACKEND_URL=http://localhost:5678
NEXT_PUBLIC_BACKEND_DEV_URL=http://localhost:5678

# AI runtime (server-only)
# Prefer the generic LLM_* variables for Anthropic-compatible providers.
LLM_BASE_URL=
LLM_MODEL=claude-sonnet-4-6
LLM_API_KEY=

# Optional fallback for the official Anthropic API.
ANTHROPIC_API_KEY=
